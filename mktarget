#!/usr/bin/env python3
"""
mktarget - Generate a Dunfield Micro-C 6809 target from a config file.

Usage:
  mktarget <config.cfg> <target_dir>

  config.cfg     target configuration in assembler SET format
  target_dir     output directory (e.g. targets/myboard)

The script generates target_dir/lib09/ containing:
  6809RLP.ASM    startup prefix (ORG, LDS, exit stub, runtime library)
  SERIO.ASM      I/O driver (from drivers/ library)
  6809RLS.ASM    suffix (heap marker, optional vector table)
  *.ASM          copied from base lib09/ (invariant runtime modules)
  EXTINDEX.LIB   copied from base lib09/

See targets/usim09/usim09.cfg for a fully-commented reference config.
"""

import sys, os, re, shutil, textwrap

# ── locate the toolchain root ──────────────────────────────────────────────
SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
LIB09_DIR  = os.path.join(SCRIPT_DIR, 'lib09')
DRV_DIR    = os.path.join(SCRIPT_DIR, 'drivers')
RUNTIME    = os.path.join(DRV_DIR, '_runtime.asm')

# ── config defaults ────────────────────────────────────────────────────────
DEFAULTS = {
    'CODE_ORG':    0x2000,
    'STACK_TOP':   0x8000,
    'RAM_ORG':     0x0100,  # RAM base for uninitialised globals (6809RLM.ASM ORG)
    'ROM_TARGET':  0,
    'VECTOR_ORG':  0xFFF0,
    'EXIT_MODE':   0,       # 0=spin, 1=jump EXIT_ADDR, 2=SWI
    'EXIT_ADDR':   0xE082,
    'IO_DRIVER':   'mc6850',
    'UART_BASE':   0xC000,
    'UART_STATUS': 0,
    'UART_DATA':   1,
    'UART_TXRDY':  0x02,
    'UART_RXRDY':  0x01,
    'UART_CRLF':   1,
}

# ── config parser ──────────────────────────────────────────────────────────
def parse_cfg(path):
    """Parse SET-format config file. Returns dict of {NAME: value}."""
    cfg = dict(DEFAULTS)
    hex_re  = re.compile(r'^\$([0-9A-Fa-f]+)$')
    int_re  = re.compile(r'^(\d+)$')
    str_re  = re.compile(r'^"([^"]*)"$')

    with open(path) as f:
        for lineno, line in enumerate(f, 1):
            # strip CRLF and comments
            line = line.rstrip('\r\n')
            if '*' in line:
                line = line[:line.index('*')]
            line = line.strip()
            if not line:
                continue

            # expect: NAME  SET  VALUE
            parts = line.split()
            if len(parts) < 3 or parts[1].upper() != 'SET':
                continue

            name  = parts[0].upper()
            token = parts[2]

            m = hex_re.match(token)
            if m:
                cfg[name] = int(m.group(1), 16)
                continue
            m = int_re.match(token)
            if m:
                cfg[name] = int(m.group(1))
                continue
            m = str_re.match(token)
            if m:
                cfg[name] = m.group(1)
                continue

            print(f"  WARNING: cannot parse value {token!r} on line {lineno}, skipping")

    return cfg

# ── hex formatter ──────────────────────────────────────────────────────────
def hex4(v):
    return f'${v:04X}'

def hex2(v):
    return f'${v:02X}'

# ── 6809RLP.ASM generator ─────────────────────────────────────────────────
def generate_rlp(cfg):
    code_org   = hex4(cfg['CODE_ORG'])
    stack_top  = hex4(cfg['STACK_TOP'])

    exit_mode = cfg['EXIT_MODE']
    if exit_mode == 0:
        exit_stub = ('* Return from main - spin forever\n'
                     '?exit1\tBRA\t?exit1\n')
    elif exit_mode == 1:
        exit_addr = hex4(cfg['EXIT_ADDR'])
        exit_stub = (f'* Return from main - jump to monitor at {exit_addr}\n'
                     f'?exit1\tJMP\t{exit_addr}\n')
    elif exit_mode == 2:
        exit_stub = ('* Return from main - software interrupt (trap to ROM handler)\n'
                     '?exit1\tSWI\n'
                     '\tBRA\t?exit1\t\t\tIn case SWI returns\n')
    else:
        exit_stub = '?exit1\tBRA\t?exit1\n'

    with open(RUNTIME) as f:
        runtime = f.read()

    return (
        f'*\n'
        f'* 6809RLP.ASM - Generated by mktarget\n'
        f'* CODE_ORG={code_org}  STACK_TOP={stack_top}\n'
        f'*\n'
        f'\tORG\t{code_org}\t\tCode base address\n'
        f'\n'
        f'* Startup - entered via reset vector\n'
        f'?begin\tLDS\t#{stack_top}\t\tInitialise stack\n'
        f'\tCLR\t?heap\t\t\tZero heap pointer\n'
        f'\tJSR\tmain\t\t\tCall user program\n'
        f'\n'
        f'{exit_stub}'
        f'\n'
        f'{runtime}'
    )

# ── 6809RLS.ASM generator ─────────────────────────────────────────────────
def generate_rls(cfg):
    out = ('*\n'
           '* 6809RLS.ASM - Generated by mktarget\n'
           '*\n'
           '?heap\tEQU\t*\t\t\tHeap starts here\n')

    if cfg['ROM_TARGET']:
        vec_org = hex4(cfg['VECTOR_ORG'])
        out += (f'\n'
                f'* 6809 hardware vector table\n'
                f'\tORG\t{vec_org}\n'
                f'\tFDB\t?begin\t\t\tUNDEF  -> reset\n'
                f'\tFDB\t?begin\t\t\tSWI3   -> reset\n'
                f'\tFDB\t?begin\t\t\tSWI2   -> reset\n'
                f'\tFDB\t?begin\t\t\tFIRQ   -> reset\n'
                f'\tFDB\t?begin\t\t\tIRQ    -> reset\n'
                f'\tFDB\t?begin\t\t\tSWI    -> reset\n'
                f'\tFDB\t?begin\t\t\tNMI    -> reset\n'
                f'\tFDB\t?begin\t\t\tRESET  -> startup\n')
    return out

# ── 6809RLM.ASM generator ─────────────────────────────────────────────────
def generate_rlm(cfg):
    ram_org = hex4(cfg['RAM_ORG'])
    return (
        '$FS:\n'
        '*#map1 Set address of un-initialized variables\n'
        f'* Generated by mktarget: globals placed in RAM at {ram_org}\n'
        f'\tORG\t{ram_org}\t\tRAM begins here\n'
    )

# ── driver installer ──────────────────────────────────────────────────────
def install_driver(cfg, out_path):
    drv_name = cfg['IO_DRIVER']
    drv_file = os.path.join(DRV_DIR, drv_name + '.asm')

    if not os.path.exists(drv_file):
        available = [os.path.splitext(f)[0]
                     for f in os.listdir(DRV_DIR)
                     if f.endswith('.asm') and not f.startswith('_')]
        print(f"  ERROR: driver '{drv_name}' not found in {DRV_DIR}/")
        print(f"  Available drivers: {', '.join(sorted(available))}")
        sys.exit(1)

    with open(drv_file) as f:
        src = f.read()

    # Parametric substitution for UART drivers
    subs = {
        '{UART_BASE}':    hex4(cfg['UART_BASE']),
        '{UART_STATUS}':  str(cfg['UART_STATUS']),
        '{UART_DATA}':    str(cfg['UART_DATA']),
        '{UART_TXRDY}':   hex2(cfg['UART_TXRDY']),
        '{UART_RXRDY}':   hex2(cfg['UART_RXRDY']),
    }
    for placeholder, value in subs.items():
        src = src.replace(placeholder, value)

    # CRLF translation conditional lines
    # Lines tagged {CRLF_YES} are included only when UART_CRLF=1
    # Lines tagged {CRLF_NO}  are included only when UART_CRLF=0
    crlf = cfg['UART_CRLF']
    lines = []
    for line in src.splitlines():
        if '{CRLF_YES}' in line:
            if crlf:
                lines.append(line.replace('{CRLF_YES}', ''))
            # else skip the line entirely
        elif '{CRLF_NO}' in line:
            if not crlf:
                lines.append(line.replace('{CRLF_NO}', ''))
            # else skip
        else:
            lines.append(line)
    src = '\n'.join(lines) + '\n'

    with open(out_path, 'w') as f:
        f.write(src)

# ── main ───────────────────────────────────────────────────────────────────
def main():
    if len(sys.argv) != 3:
        print(__doc__)
        sys.exit(1)

    cfg_path = sys.argv[1]
    tgt_dir  = sys.argv[2]

    if not os.path.exists(cfg_path):
        print(f"Error: config file not found: {cfg_path}")
        sys.exit(1)

    lib09_out = os.path.join(tgt_dir, 'lib09')

    print(f"mktarget: reading {cfg_path}")
    cfg = parse_cfg(cfg_path)

    print(f"  CODE_ORG    = {hex4(cfg['CODE_ORG'])}")
    print(f"  STACK_TOP   = {hex4(cfg['STACK_TOP'])}")
    print(f"  ROM_TARGET  = {cfg['ROM_TARGET']}")
    if cfg['ROM_TARGET']:
        print(f"  VECTOR_ORG  = {hex4(cfg['VECTOR_ORG'])}")
    print(f"  EXIT_MODE   = {cfg['EXIT_MODE']} "
          f"({'spin' if cfg['EXIT_MODE']==0 else 'jump' if cfg['EXIT_MODE']==1 else 'SWI'})")
    if cfg['EXIT_MODE'] == 1:
        print(f"  EXIT_ADDR   = {hex4(cfg['EXIT_ADDR'])}")
    print(f"  RAM_ORG     = {hex4(cfg['RAM_ORG'])}")
    print(f"  IO_DRIVER   = {cfg['IO_DRIVER']}")

    print(f"\nmktarget: generating {lib09_out}/")
    os.makedirs(lib09_out, exist_ok=True)

    # Generate the three variable files
    rlp_path = os.path.join(lib09_out, '6809RLP.ASM')
    with open(rlp_path, 'w') as f:
        f.write(generate_rlp(cfg))
    print(f"  wrote 6809RLP.ASM")

    rlm_path = os.path.join(lib09_out, '6809RLM.ASM')
    with open(rlm_path, 'w') as f:
        f.write(generate_rlm(cfg))
    print(f"  wrote 6809RLM.ASM")

    serio_path = os.path.join(lib09_out, 'SERIO.ASM')
    install_driver(cfg, serio_path)
    print(f"  wrote SERIO.ASM  (driver: {cfg['IO_DRIVER']})")

    rls_path = os.path.join(lib09_out, '6809RLS.ASM')
    with open(rls_path, 'w') as f:
        f.write(generate_rls(cfg))
    print(f"  wrote 6809RLS.ASM")

    # Copy invariant library files from base lib09/
    skip = {'SERIO.ASM', '6809RLS.ASM', '6809RLP.ASM', '6809RLM.ASM'}
    copied = 0
    for fname in os.listdir(LIB09_DIR):
        if fname in skip:
            continue
        if not (fname.endswith('.ASM') or fname.endswith('.LIB')):
            continue
        shutil.copy2(os.path.join(LIB09_DIR, fname),
                     os.path.join(lib09_out, fname))
        copied += 1
    print(f"  copied {copied} library files from lib09/")

    print(f"\nmktarget: done.")
    print(f"\nTo build:")
    print(f"  MCDIR=. MCINCLUDE=./include MCLIBDIR={lib09_out} \\")
    print(f"    cc09 prog.c -Iq")

if __name__ == '__main__':
    main()
